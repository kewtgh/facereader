{
  "name": "minimal-mistakes",
  "private": true,
  "version": "4.28.0",
  "description": "FaceReader custom site based on Minimal Mistakes 4.28.0, heavily refactored for Witbacon.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmistakes/minimal-mistakes.git"
  },
  "keywords": [
    "jekyll",
    "theme",
    "minimal"
  ],
  "author": "Michael Rose",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mmistakes/minimal-mistakes/issues"
  },
  "homepage": "https://mmistakes.github.io/minimal-mistakes/",
  "engines": {
    "node": ">= 18"
  },
  "type": "module",
  "scripts": {
    "leaders:validate": "node assets/scripts/validate-leaders-data.mjs",
    "site:build": "bundle exec ruby -r./_plugins/liquid_taint_compat.rb -S jekyll build",
    "site:links": "node assets/scripts/check-internal-links.mjs",
    "site:check": "npm run leaders:validate && npm run site:build && npm run site:links",
    "algolia:push": "node assets/scripts/push-algolia.mjs _site/algolia-records.json"
  },
  "dependencies": {
    "algoliasearch": "^5.48.1",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "uglify-js": "^3.17.4"
  }
}
