{
  "name": "facereader",
  "private": true,
  "version": "6.9.5",
  "description": "FaceReader production site for enterprise observation and leadership analysis.",
  "repository": {
    "type": "git",
    "url": "https://github.com/kewtgh/facereader.git"
  },
  "keywords": [
    "jekyll",
    "facereader",
    "enterprise-analysis"
  ],
  "author": "FaceReader",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kewtgh/facereader/issues"
  },
  "homepage": "https://facereader.witbacon.com/",
  "engines": {
    "node": ">= 18"
  },
  "type": "module",
  "scripts": {
    "build": "npm run site:build",
    "leaders:validate": "node assets/scripts/validate-leaders-data.mjs",
    "leaders:audit": "node assets/scripts/audit-leaders-score-rubric.mjs",
    "actions:lint": "node assets/scripts/validate-actions-workflows.mjs",
    "site:build": "bundle exec ruby -EUTF-8 -r./_plugins/liquid_taint_compat.rb -S jekyll build",
    "site:links": "node assets/scripts/check-internal-links.mjs",
    "site:check": "npm run leaders:validate && npm run leaders:audit && npm run site:build && npm run site:links",
    "algolia:push": "node assets/scripts/push-algolia.mjs _site/algolia-records.json"
  },
  "dependencies": {
    "algoliasearch": "^5.48.1",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "uglify-js": "^3.17.4"
  }
}
